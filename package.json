{
  "name": "zhijian",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cf:dev": "wrangler dev",
    "db:local": "wrangler d1 migrations apply zhijian-db --local",
    "db:remote": "wrangler d1 migrations apply zhijian-db --remote",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@hono/zod-validator": "latest",
    "hono": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest",
    "wrangler": "latest"
  }
}
